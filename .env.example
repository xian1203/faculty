# Cloudinary Configuration
# Sign up at https://cloudinary.com/ to get these values
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_PRESET=your_upload_preset_name

# Instructions:
# 1. Create a Cloudinary account at https://cloudinary.com/
# 2. Get your Cloud Name from the dashboard
# 3. Create an unsigned upload preset named 'honesty_store' in your Cloudinary settings
# 4. Copy the values to .env file (this file is for reference only)
